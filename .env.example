# --- Base de datos (Postgres / Vercel Postgres / Neon / Supabase) ---
DATABASE_URL="postgres://user:pass@host:5432/tobyap"

# --- Cifrado de secretos en DB (AES-256-GCM) ---
# 32 bytes en hex (64 chars). Generala una vez con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# --- Alta de tenants (endpoint admin) ---
ADMIN_TOKEN=""

# --- Sesión del panel (firma de cookie) ---
# 32 bytes hex, mismo método que ENCRYPTION_KEY
SESSION_SECRET=""

# --- Meta (solo desarrollo): ver eventos en "Eventos de prueba" sin impactar atribución ---
META_TEST_EVENT_CODE=""
